<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_view_form_si" model="ir.ui.view">
        <field name="name">hr.employee.form.si</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_si_records" type="object"
                        class="oe_stat_button" icon="fa-medkit"
                        groups="hr.group_hr_user" invisible="not id">
                    <field name="si_record_count" widget="statinfo"
                           string="Hồ sơ BH"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>

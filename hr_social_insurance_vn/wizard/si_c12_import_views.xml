<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="si_c12_import_view_form" model="ir.ui.view">
        <field name="name">hr.vn.si.c12.import.form</field>
        <field name="model">hr.vn.si.c12.import</field>
        <field name="arch" type="xml">
            <form string="Import tra cứu C12">
                <group>
                    <field name="month"/>
                    <field name="year"/>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <div class="alert alert-info" role="alert">
                    <strong>Định dạng file Excel:</strong><br/>
                    Cột 1: Số sổ BHXH | Cột 2: Tình trạng | Cột 3: BHXH |
                    Cột 4: BHYT | Cột 5: BHTN
                </div>
                <footer>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="si_c12_import_action" model="ir.actions.act_window">
        <field name="name">Import C12</field>
        <field name="res_model">hr.vn.si.c12.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

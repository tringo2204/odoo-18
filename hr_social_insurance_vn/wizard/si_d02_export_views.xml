<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="si_d02_export_view_form" model="ir.ui.view">
        <field name="name">hr.vn.si.d02.export.form</field>
        <field name="model">hr.vn.si.d02.export</field>
        <field name="arch" type="xml">
            <form string="Xuất báo cáo D02-LT">
                <group>
                    <field name="monthly_list_id"/>
                    <field name="month"/>
                    <field name="year"/>
                </group>
                <footer>
                    <button name="action_export" string="Xuất báo cáo" type="object"
                            class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="si_bhxh_export_view_form" model="ir.ui.view">
        <field name="name">hr.vn.si.bhxh.export.form</field>
        <field name="model">hr.vn.si.bhxh.export</field>
        <field name="arch" type="xml">
            <form string="Xuất mẫu BHXH">
                <group>
                    <field name="report_type"/>
                    <field name="month"/>
                    <field name="year"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="export_file" filename="export_filename"
                           invisible="not export_file"/>
                    <field name="export_filename" invisible="1"/>
                </group>
                <div class="alert alert-info" role="alert">
                    <strong>Mẫu báo cáo BHXH:</strong><br/>
                    TK1-TS: Tờ khai đơn vị | D02-TS: DS lao động | D03-TS: DS đóng BHXH
                </div>
                <footer>
                    <button name="action_export" string="Xuất file" type="object"
                            class="btn-primary"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_si_bhxh_export" model="ir.actions.act_window">
        <field name="name">Xuất mẫu BHXH</field>
        <field name="res_model">hr.vn.si.bhxh.export</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

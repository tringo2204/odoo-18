        <record id="seq_hr_vn_si_record" model="ir.sequence">
            <field name="name">Hồ sơ bảo hiểm</field>
            <field name="code">hr.vn.si.record</field>
            <field name="prefix">BHXH-%(year)s/</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_hr_vn_si_d02_report" model="ir.sequence">
            <field name="name">Báo cáo D02-LT</field>
            <field name="code">hr.vn.si.d02.report</field>

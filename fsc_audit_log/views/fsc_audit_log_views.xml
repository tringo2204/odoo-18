<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fsc_audit_log_view_list" model="ir.ui.view">
        <field name="name">fsc.audit.log.list</field>
        <field name="model">fsc.audit.log</field>
        <field name="arch" type="xml">
            <list string="Audit Log" create="false" edit="false" delete="false">
                <field name="create_date"/>
                <field name="user_id"/>
                <field name="model_name"/>
                <field name="res_id"/>
                <field name="action"/>
                <field name="field_name"/>
                <field name="old_value"/>
                <field name="new_value"/>
                <field name="reason"/>
            </list>
        </field>
    </record>

    <record id="fsc_audit_log_view_form" model="ir.ui.view">
        <field name="name">fsc.audit.log.form</field>
        <field name="model">fsc.audit.log</field>
        <field name="arch" type="xml">
            <form string="Audit Log" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="create_date"/>
                            <field name="user_id"/>
                            <field name="action"/>
                        </group>
                        <group>
                            <field name="model_name"/>
                            <field name="res_id"/>
                            <field name="res_ref"/>
                            <field name="field_name"/>
                        </group>
                    </group>
                    <group string="Change">
                        <field name="old_value"/>
                        <field name="new_value"/>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="fsc_audit_log_view_search" model="ir.ui.view">
        <field name="name">fsc.audit.log.search</field>
        <field name="model">fsc.audit.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="model_name"/>
                <field name="res_id"/>
                <field name="user_id"/>
                <field name="field_name"/>
                <field name="reason"/>
                <filter name="filter_create" string="Create" domain="[('action','=','create')]"/>
                <filter name="filter_write" string="Write" domain="[('action','=','write')]"/>
                <filter name="filter_unlink" string="Unlink" domain="[('action','=','unlink')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_model" string="Model" context="{'group_by':'model_name'}"/>
                    <filter name="group_user" string="User" context="{'group_by':'user_id'}"/>
                    <filter name="group_action" string="Action" context="{'group_by':'action'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="fsc_audit_log_action" model="ir.actions.act_window">
        <field name="name">FSC Audit Log</field>
        <field name="res_model">fsc.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="fsc_audit_log_view_search"/>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_view_form_decision" model="ir.ui.view">
        <field name="name">hr.employee.form.decision</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_decisions" type="object"
                        class="o_stat_button" icon="fa-gavel"
                        groups="hr.group_hr_user" invisible="not id">
                    <field name="decision_count" widget="statinfo" string="Quyết định"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Quá trình làm việc" name="work_history"
                      groups="hr.group_hr_user">
                    <field name="work_history_html" nolabel="1"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

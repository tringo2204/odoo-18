<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_leave_hr_leave_allocation_view_form" model="ir.ui.view">
        <field name="name">hr.leave.allocation.form.sht.hr.leave</field>
        <field name="model">hr.leave.allocation</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='duration_display']" position="after">
                <field name="sht_seniority_bonus_days" readonly="1"
                    invisible="not holiday_status_id.sht_seniority_bonus"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_recruitment_headcount_plan_view_list" model="ir.ui.view">
        <field name="name">sht.hr.headcount.plan.list</field>
        <field name="model">sht.hr.headcount.plan</field>
        <field name="arch" type="xml">
            <list string="Headcount Plans" decoration-danger="is_over_budget">
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="planned_count"/>
                <field name="current_count"/>
                <field name="remaining"/>
                <field name="is_over_budget"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'approved'"
                    decoration-muted="state == 'closed'"
                    decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_recruitment_headcount_plan_view_form" model="ir.ui.view">
        <field name="name">sht.hr.headcount.plan.form</field>
        <field name="model">sht.hr.headcount.plan</field>
        <field name="arch" type="xml">
            <form string="Headcount Plan">
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary"
                        invisible="state != 'draft'"/>
                    <button name="action_close" type="object" string="Close"
                        invisible="state != 'approved'"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                        groups="hr.group_hr_manager"
                        invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,approved,closed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Plan">
                            <field name="name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                        </group>
                        <group string="Period">
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group>
                        <group string="Headcount">
                            <field name="planned_count"/>
                            <field name="current_count"/>
                            <field name="remaining"/>
                            <field name="is_over_budget"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="note" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sht_hr_recruitment_headcount_plan_view_search" model="ir.ui.view">
        <field name="name">sht.hr.headcount.plan.search</field>
        <field name="model">sht.hr.headcount.plan</field>
        <field name="arch" type="xml">
            <search string="Headcount Plans">
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <separator/>
                <filter string="Over Budget" name="sht_over_budget" domain="[('is_over_budget', '=', True)]"/>
                <filter string="Approved" name="sht_approved" domain="[('state', '=', 'approved')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Department" name="sht_group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Job" name="sht_group_job" context="{'group_by': 'job_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="sht_hr_recruitment_headcount_plan_action" model="ir.actions.act_window">
        <field name="name">Headcount Plans</field>
        <field name="res_model">sht.hr.headcount.plan</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sht_hr_recruitment_headcount_plan_view_search"/>
        <field name="context">{}</field>
    </record>
</odoo>

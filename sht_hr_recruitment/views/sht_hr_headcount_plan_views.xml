<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_recruitment_headcount_plan_view_list" model="ir.ui.view">
        <field name="name">sht.hr.headcount.plan.list</field>
        <field name="model">sht.hr.headcount.plan</field>
        <field name="arch" type="xml">
            <list string="Kế hoạch định biên" decoration-danger="is_over_budget">
                <field name="name" string="Tên kế hoạch"/>
                <field name="department_id" string="Phòng ban"/>
                <field name="job_id" string="Vị trí"/>
                <field name="planned_count" string="Định biên"/>
                <field name="current_count" string="Hiện tại"/>
                <field name="remaining" string="Còn thiếu"/>
                <field name="date_from" string="Từ ngày"/>
                <field name="date_to" string="Đến ngày"/>
                <field name="is_over_budget" string="Vượt định biên"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'approved'"
                    decoration-muted="state == 'closed'"
                    decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_recruitment_headcount_plan_view_form" model="ir.ui.view">
        <field name="name">sht.hr.headcount.plan.form</field>
        <field name="model">sht.hr.headcount.plan</field>
        <field name="arch" type="xml">
            <form string="Kế hoạch định biên">
                <header>
                    <button name="action_approve" type="object" string="Phê duyệt" class="btn-primary"
                        invisible="state != 'draft'"
                        groups="hr.group_hr_manager"/>
                    <button name="action_close" type="object" string="Đóng kế hoạch"
                        invisible="state != 'approved'"/>
                    <button name="action_reset_draft" type="object" string="Đặt lại nháp"
                        groups="hr.group_hr_manager"
                        invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,approved,closed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Thông tin kế hoạch">
                            <field name="name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                        </group>
                        <group string="Thời gian">
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group>
                        <group string="Số lượng nhân sự">
                            <field name="planned_count"/>
                            <field name="current_count"/>
                            <field name="applicant_count"/>
                            <field name="remaining"/>
                            <field name="is_over_budget"/>
                        </group>
                    </group>
                    <group string="Ghi chú">
                        <field name="note" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="sht_hr_recruitment_headcount_plan_view_search" model="ir.ui.view">
        <field name="name">sht.hr.headcount.plan.search</field>
        <field name="model">sht.hr.headcount.plan</field>
        <field name="arch" type="xml">
            <search string="Kế hoạch định biên">
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <separator/>
                <filter string="Vượt định biên" name="sht_over_budget" domain="[('is_over_budget', '=', True)]"/>
                <filter string="Đã duyệt" name="sht_approved" domain="[('state', '=', 'approved')]"/>
                <separator/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Phòng ban" name="sht_group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Vị trí" name="sht_group_job" context="{'group_by': 'job_id'}"/>
                    <filter string="Trạng thái" name="sht_group_state" context="{'group_by': 'state'}"/>
                    <filter string="Tháng" name="sht_group_month" context="{'group_by': 'date_from:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- #189: Pivot view for headcount staffing table -->
    <record id="sht_hr_recruitment_headcount_plan_view_pivot" model="ir.ui.view">
        <field name="name">sht.hr.headcount.plan.pivot</field>
        <field name="model">sht.hr.headcount.plan</field>
        <field name="arch" type="xml">
            <pivot string="Bảng định biên" disable_linking="0">
                <field name="department_id" type="row"/>
                <field name="job_id" type="row"/>
                <field name="state" type="col"/>
                <field name="planned_count" type="measure" string="Định biên"/>
                <field name="current_count" type="measure" string="Hiện tại"/>
                <field name="remaining" type="measure" string="Còn thiếu"/>
                <field name="applicant_count" type="measure" string="Ứng viên"/>
            </pivot>
        </field>
    </record>

    <!-- #189: Graph view for headcount overview -->
    <record id="sht_hr_recruitment_headcount_plan_view_graph" model="ir.ui.view">
        <field name="name">sht.hr.headcount.plan.graph</field>
        <field name="model">sht.hr.headcount.plan</field>
        <field name="arch" type="xml">
            <graph string="Định biên theo phòng ban" type="bar" stacked="0">
                <field name="department_id" type="row"/>
                <field name="planned_count" type="measure" string="Định biên"/>
                <field name="current_count" type="measure" string="Hiện tại"/>
                <field name="remaining" type="measure" string="Còn thiếu"/>
            </graph>
        </field>
    </record>

    <record id="sht_hr_recruitment_headcount_plan_action" model="ir.actions.act_window">
        <field name="name">Kế hoạch định biên</field>
        <field name="res_model">sht.hr.headcount.plan</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="search_view_id" ref="sht_hr_recruitment_headcount_plan_view_search"/>
        <field name="context">{}</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_recruitment_campaign_view_form" model="ir.ui.view">
        <field name="name">sht.hr.recruitment.campaign.form</field>
        <field name="model">sht.hr.recruitment.campaign</field>
        <field name="arch" type="xml">
            <form string="Chiến dịch tuyển dụng">
                <header>
                    <button name="action_start" string="Bắt đầu" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" string="Đóng" type="object"
                            invisible="state != 'active'"/>
                    <button name="action_draft" string="Về nháp" type="object"
                            invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_applicants" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="hired_count"/>/<field name="applicant_count"/>
                                </span>
                                <span class="o_stat_text">Ứng viên</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Tên chiến dịch..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="request_id"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                            <field name="responsible_id"/>
                        </group>
                        <group>
                            <field name="channel"/>
                            <field name="budget"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Ghi chú..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="sht_hr_recruitment_campaign_view_list" model="ir.ui.view">
        <field name="name">sht.hr.recruitment.campaign.list</field>
        <field name="model">sht.hr.recruitment.campaign</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'"
                  decoration-success="state == 'active'"
                  decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="channel"/>
                <field name="applicant_count"/>
                <field name="hired_count"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_recruitment_campaign_action" model="ir.actions.act_window">
        <field name="name">Chiến dịch tuyển dụng</field>
        <field name="res_model">sht.hr.recruitment.campaign</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

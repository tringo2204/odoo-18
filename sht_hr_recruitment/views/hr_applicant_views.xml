<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_recruitment_applicant_view_form_headcount" model="ir.ui.view">
        <field name="name">hr.applicant.form.headcount</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <field name="department_id" position="after">
                <field name="campaign_id"/>
                <field name="headcount_plan_id"/>
                <field name="source_channel"/>
                <field name="evaluation_score"/>
                <field name="is_over_budget" invisible="1"/>
            </field>
        </field>
    </record>

    <record id="sht_hr_recruitment_applicant_view_list_headcount" model="ir.ui.view">
        <field name="name">hr.applicant.list.headcount</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.crm_case_tree_view_job"/>
        <field name="arch" type="xml">
            <field name="job_id" position="after">
                <field name="campaign_id" optional="hide"/>
                <field name="evaluation_score" optional="hide"/>
            </field>
        </field>
    </record>
</odoo>

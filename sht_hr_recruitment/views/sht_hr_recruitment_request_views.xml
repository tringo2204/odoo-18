<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_recruitment_request_view_form" model="ir.ui.view">
        <field name="name">sht.hr.recruitment.request.form</field>
        <field name="model">sht.hr.recruitment.request</field>
        <field name="arch" type="xml">
            <form string="Đề xuất tuyển dụng">
                <header>
                    <button name="action_submit" string="Trình duyệt" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Phê duyệt" type="object"
                            class="btn-primary" invisible="state != 'submitted'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_reject" string="Từ chối" type="object"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_create_campaign" string="Tạo chiến dịch" type="object"
                            class="btn-success" invisible="state != 'approved'"/>
                    <button name="action_draft" string="Về nháp" type="object"
                            invisible="state not in ('submitted', 'rejected')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_campaigns" type="object"
                                class="oe_stat_button" icon="fa-bullhorn"
                                invisible="campaign_count == 0">
                            <field name="campaign_count" widget="statinfo" string="Chiến dịch"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="department_id"/>
                            <field name="job_id"/>
                            <field name="request_type"/>
                            <field name="quantity"/>
                        </group>
                        <group>
                            <field name="requested_by"/>
                            <field name="approved_by"/>
                            <field name="approved_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="reason" placeholder="Lý do đề xuất tuyển dụng..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="sht_hr_recruitment_request_view_list" model="ir.ui.view">
        <field name="name">sht.hr.recruitment.request.list</field>
        <field name="model">sht.hr.recruitment.request</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'"
                  decoration-warning="state == 'submitted'"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="request_type"/>
                <field name="quantity"/>
                <field name="requested_by"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_recruitment_request_view_search" model="ir.ui.view">
        <field name="name">sht.hr.recruitment.request.search</field>
        <field name="model">sht.hr.recruitment.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <filter string="Chờ duyệt" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Đã duyệt" name="approved" domain="[('state', '=', 'approved')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Phòng ban" name="group_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="Trạng thái" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="sht_hr_recruitment_request_action" model="ir.actions.act_window">
        <field name="name">Đề xuất tuyển dụng</field>
        <field name="res_model">sht.hr.recruitment.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sht_hr_recruitment_request_view_search"/>
    </record>
</odoo>

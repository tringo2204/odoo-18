<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Multi-company rule -->
    <record id="sht_hr_health_comp_rule" model="ir.rule">
        <field name="name">Sức khoẻ: Multi-company</field>
        <field name="model_id" ref="model_sht_hr_health_record"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <!-- HR users see only own employees' records -->
    <record id="sht_hr_health_user_rule" model="ir.rule">
        <field name="name">Sức khoẻ: Nhân viên — chỉ thấy hồ sơ của mình</field>
        <field name="model_id" ref="model_sht_hr_health_record"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>

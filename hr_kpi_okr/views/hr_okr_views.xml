<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_okr_objective_view_form" model="ir.ui.view">
        <field name="name">hr.okr.objective.form</field>
        <field name="model">hr.okr.objective</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" string="Bắt đầu" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" string="Hoàn thành" type="object" class="btn-success" invisible="state != 'active'"/>
                    <button name="action_cancel" string="Hủy" type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_draft" string="Về nháp" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" placeholder="Mục tiêu..."/></h1></div>
                    <group>
                        <group>
                            <field name="owner_id"/><field name="parent_id"/><field name="period_id"/>
                        </group>
                        <group>
                            <field name="progress" widget="progressbar"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Key Results">
                            <field name="key_result_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/><field name="target_value"/><field name="current_value"/>
                                    <field name="unit"/><field name="progress" widget="progressbar"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Mục tiêu con">
                            <field name="child_ids">
                                <list><field name="name"/><field name="owner_id"/><field name="progress" widget="progressbar"/><field name="state" widget="badge"/></list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="hr_okr_objective_view_list" model="ir.ui.view">
        <field name="name">hr.okr.objective.list</field>
        <field name="model">hr.okr.objective</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/><field name="owner_id"/><field name="parent_id"/>
                <field name="progress" widget="progressbar"/><field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="hr_okr_objective_action" model="ir.actions.act_window">
        <field name="name">OKR Objectives</field>
        <field name="res_model">hr.okr.objective</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

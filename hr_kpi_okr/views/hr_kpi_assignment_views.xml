<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_kpi_assignment_view_form" model="ir.ui.view">
        <field name="name">hr.kpi.assignment.form</field>
        <field name="model">hr.kpi.assignment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Nộp" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_evaluate" string="Đánh giá" type="object" invisible="state != 'submitted'" groups="hr.group_hr_manager"/>
                    <button name="action_done" string="Hoàn thành" type="object" class="btn-success" invisible="state != 'evaluated'" groups="hr.group_hr_manager"/>
                    <button name="action_draft" string="Về nháp" type="object" invisible="state in ('draft', 'done')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,evaluated,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="period_id"/><field name="employee_id"/><field name="department_id"/>
                        </group>
                        <group>
                            <field name="template_id"/><field name="overall_score"/>
                            <field name="rating" widget="badge"
                                   decoration-success="rating in ('excellent', 'good')"
                                   decoration-warning="rating == 'meet'"
                                   decoration-danger="rating == 'improve'"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="criteria_id"/><field name="category" widget="badge"/>
                            <field name="weight"/><field name="target_value"/><field name="actual_value"/>
                            <field name="score"/><field name="note"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="hr_kpi_assignment_view_list" model="ir.ui.view">
        <field name="name">hr.kpi.assignment.list</field>
        <field name="model">hr.kpi.assignment</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/><field name="period_id"/><field name="department_id"/>
                <field name="overall_score"/><field name="rating" widget="badge"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="hr_kpi_assignment_action" model="ir.actions.act_window">
        <field name="name">Phân công KPI</field>
        <field name="res_model">hr.kpi.assignment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_kpi_template_view_form" model="ir.ui.view">
        <field name="name">hr.kpi.template.form</field>
        <field name="model">hr.kpi.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/><field name="department_id"/><field name="job_id"/>
                        </group>
                        <group>
                            <field name="total_weight"/><field name="active"/>
                        </group>
                    </group>
                    <field name="criteria_ids">
                        <list><field name="code"/><field name="name"/><field name="category" widget="badge"/><field name="weight"/></list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
    <record id="hr_kpi_template_view_list" model="ir.ui.view">
        <field name="name">hr.kpi.template.list</field>
        <field name="model">hr.kpi.template</field>
        <field name="arch" type="xml">
            <list><field name="name"/><field name="department_id"/><field name="job_id"/><field name="total_weight"/></list>
        </field>
    </record>
    <record id="hr_kpi_template_action" model="ir.actions.act_window">
        <field name="name">Mẫu KPI</field>
        <field name="res_model">hr.kpi.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

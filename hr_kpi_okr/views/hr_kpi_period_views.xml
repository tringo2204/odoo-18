<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_kpi_period_view_form" model="ir.ui.view">
        <field name="name">hr.kpi.period.form</field>
        <field name="model">hr.kpi.period</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" string="Bắt đầu" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_generate_assignments" string="Tạo KPI" type="object" class="btn-primary" invisible="state != 'in_progress'"/>
                    <button name="action_complete" string="Hoàn thành" type="object" class="btn-success" invisible="state != 'in_progress'"/>
                    <button name="action_draft" string="Về nháp" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="period_type"/><field name="date_from"/><field name="date_to"/>
                        </group>
                        <group>
                            <field name="template_id"/><field name="department_ids" widget="many2many_tags"/>
                            <field name="total_count"/><field name="completed_count"/>
                        </group>
                    </group>
                    <field name="assignment_ids">
                        <list>
                            <field name="employee_id"/><field name="department_id"/>
                            <field name="overall_score"/><field name="rating" widget="badge"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="hr_kpi_period_view_list" model="ir.ui.view">
        <field name="name">hr.kpi.period.list</field>
        <field name="model">hr.kpi.period</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/><field name="period_type"/><field name="date_from"/><field name="date_to"/>
                <field name="total_count"/><field name="completed_count"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="hr_kpi_period_action" model="ir.actions.act_window">
        <field name="name">Kỳ đánh giá KPI</field>
        <field name="res_model">hr.kpi.period</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_contract_hr_contract_view_form" model="ir.ui.view">
        <field name="name">hr.contract.form.sht.vietnam</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Thời hạn hợp đồng" name="sht_vietnam_contract" groups="hr.group_hr_user">
                    <group string="Thông tin hợp đồng">
                        <group>
                            <field name="sht_contract_type_id"/>
                            <field name="is_probation" readonly="1"/>
                            <field name="probation_end_date"/>
                            <field name="original_start_date"/>
                            <field name="renewal_count"/>
                        </group>
                        <group>
                            <field name="days_to_expire" readonly="1"/>
                            <field name="is_expiring_soon" readonly="1"/>
                        </group>
                    </group>
                </page>
                <page string="Termination" name="sht_termination" invisible="state != 'cancel'" groups="hr.group_hr_user">
                    <group>
                        <field name="termination_reason"/>
                        <field name="termination_date"/>
                        <field name="termination_note" nolabel="1" placeholder="Notes..."/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
    <record id="sht_hr_contract_hr_contract_view_list" model="ir.ui.view">
        <field name="name">hr.contract.list.sht.vietnam</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='contract_type_id']" position="after">
                <field name="sht_contract_type_id" optional="show" groups="hr.group_hr_user"/>
                <field name="days_to_expire" optional="show" groups="hr.group_hr_user"/>
            </xpath>
        </field>
    </record>
    <record id="sht_hr_contract_hr_contract_view_search" model="ir.ui.view">
        <field name="name">hr.contract.search.sht.vietnam</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='running']" position="after">
                <filter string="Sắp hết hạn" name="sht_expiring_soon" domain="[('is_expiring_soon', '=', True)]" groups="hr.group_hr_user"/>
            </xpath>
            <xpath expr="//group[@expand='0']" position="inside">
                <filter string="Loại hợp đồng VN" name="sht_group_contract_type" domain="[]" context="{'group_by': 'sht_contract_type_id'}" groups="hr.group_hr_user"/>
            </xpath>
        </field>
    </record>
</odoo>

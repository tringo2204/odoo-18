<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_contract_type_view_list" model="ir.ui.view">
        <field name="name">sht.hr.contract.type.list</field>
        <field name="model">sht.hr.contract.type</field>
        <field name="arch" type="xml">
            <list string="Loại hợp đồng Việt Nam">
                <field name="name"/>
                <field name="code"/>
                <field name="max_duration_months"/>
            </list>
        </field>
    </record>
    <record id="sht_hr_contract_type_view_form" model="ir.ui.view">
        <field name="name">sht.hr.contract.type.form</field>
        <field name="model">sht.hr.contract.type</field>
        <field name="arch" type="xml">
            <form string="Loại hợp đồng Việt Nam">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="max_duration_months"/>
                    </group>
                    <group>
                        <field name="description" nolabel="1" placeholder="Description..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="sht_hr_contract_type_action" model="ir.actions.act_window">
        <field name="name">Loại hợp đồng Việt Nam</field>
        <field name="res_model">sht.hr.contract.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

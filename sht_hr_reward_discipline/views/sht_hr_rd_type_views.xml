<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_rd_type_view_tree" model="ir.ui.view">
        <field name="name">sht.hr.rd.type.tree</field>
        <field name="model">sht.hr.rd.type</field>
        <field name="arch" type="xml">
            <list string="Loại khen thưởng &amp; kỷ luật">
                <field name="name" string="Tên loại"/>
                <field name="code" string="Mã" optional="show"/>
                <field name="category" string="Phân loại"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_rd_type_view_form" model="ir.ui.view">
        <field name="name">sht.hr.rd.type.form</field>
        <field name="model">sht.hr.rd.type</field>
        <field name="arch" type="xml">
            <form string="Loại khen thưởng/kỷ luật">
                <sheet>
                    <group>
                        <field name="name" string="Tên loại"/>
                        <field name="code" string="Mã"/>
                        <field name="category" string="Phân loại"/>
                    </group>
                    <group>
                        <field name="description" string="Mô tả" colspan="2" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sht_hr_rd_type_view_search" model="ir.ui.view">
        <field name="name">sht.hr.rd.type.search</field>
        <field name="model">sht.hr.rd.type</field>
        <field name="arch" type="xml">
            <search string="Loại khen thưởng/kỷ luật">
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <separator/>
                <filter string="Khen thưởng" name="filter_reward" domain="[('category', '=', 'reward')]"/>
                <filter string="Kỷ luật" name="filter_discipline" domain="[('category', '=', 'discipline')]"/>
            </search>
        </field>
    </record>

    <record id="action_sht_hr_rd_type" model="ir.actions.act_window">
        <field name="name">Loại khen thưởng/kỷ luật</field>
        <field name="res_model">sht.hr.rd.type</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sht_hr_rd_type_view_search"/>
    </record>
</odoo>

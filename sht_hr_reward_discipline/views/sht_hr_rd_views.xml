<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_rd_view_tree" model="ir.ui.view">
        <field name="name">sht.hr.rd.tree</field>
        <field name="model">sht.hr.rd</field>
        <field name="arch" type="xml">
            <list string="Khen thưởng &amp; Kỷ luật"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id" optional="show"/>
                <field name="rd_type_id"/>
                <field name="category" optional="show"/>
                <field name="date"/>
                <field name="amount" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_rd_view_form" model="ir.ui.view">
        <field name="name">sht.hr.rd.form</field>
        <field name="model">sht.hr.rd</field>
        <field name="arch" type="xml">
            <form string="Khen thưởng / Kỷ luật">
                <header>
                    <button name="action_confirm" string="Xác nhận" type="object" class="btn-primary"
                            invisible="state != 'draft'" groups="hr.group_hr_user"/>
                    <button name="action_cancel" string="Hủy" type="object"
                            invisible="state in ('draft', 'cancelled')" groups="hr.group_hr_manager"/>
                    <button name="action_reset_draft" string="Về nháp" type="object"
                            invisible="state not in ('cancelled',)" groups="hr.group_hr_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="department_id" readonly="1"/>
                            <field name="category"/>
                            <field name="rd_type_id" string="Loại"
                                   domain="[('category', '=', category)]"
                                   context="{'default_category': category}"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Quyết định">
                        <group>
                            <field name="date" string="Ngày hiệu lực"/>
                            <field name="decision_number" string="Số quyết định"/>
                            <field name="decision_date" string="Ngày quyết định"/>
                            <field name="amount" string="Giá trị (VND)"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" string="Lý do" colspan="2"/>
                    </group>
                    <group>
                        <field name="description" string="Chi tiết" colspan="2"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="sht_hr_rd_view_search" model="ir.ui.view">
        <field name="name">sht.hr.rd.search</field>
        <field name="model">sht.hr.rd</field>
        <field name="arch" type="xml">
            <search string="Khen thưởng &amp; Kỷ luật">
                <field name="name"/>
                <field name="employee_id" string="Nhân viên"/>
                <field name="department_id" string="Phòng ban"/>
                <field name="rd_type_id" string="Loại"/>
                <separator/>
                <filter string="Khen thưởng" name="filter_reward" domain="[('category', '=', 'reward')]"/>
                <filter string="Kỷ luật" name="filter_discipline" domain="[('category', '=', 'discipline')]"/>
                <separator/>
                <filter string="Nháp" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Đã xác nhận" name="filter_confirmed" domain="[('state', '=', 'confirmed')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Nhân viên" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Phòng ban" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Loại" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Tháng" name="group_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for rewards only -->
    <record id="action_sht_hr_rd_reward" model="ir.actions.act_window">
        <field name="name">Khen thưởng</field>
        <field name="res_model">sht.hr.rd</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('category', '=', 'reward')]</field>
        <field name="search_view_id" ref="sht_hr_rd_view_search"/>
        <field name="context">{'default_category': 'reward'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo hồ sơ khen thưởng cho nhân viên.</p>
        </field>
    </record>

    <!-- Action for discipline only -->
    <record id="action_sht_hr_rd_discipline" model="ir.actions.act_window">
        <field name="name">Kỷ luật</field>
        <field name="res_model">sht.hr.rd</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('category', '=', 'discipline')]</field>
        <field name="search_view_id" ref="sht_hr_rd_view_search"/>
        <field name="context">{'default_category': 'discipline'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo hồ sơ kỷ luật cho nhân viên.</p>
        </field>
    </record>

    <record id="action_sht_hr_rd" model="ir.actions.act_window">
        <field name="name">Tất cả hồ sơ</field>
        <field name="res_model">sht.hr.rd</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sht_hr_rd_view_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo hồ sơ khen thưởng hoặc kỷ luật cho nhân viên.
            </p>
        </field>
    </record>
</odoo>

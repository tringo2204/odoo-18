<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_view_form_inherit_rd" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.rd</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_rd_records"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-trophy"
                        groups="hr.group_hr_user"
                        invisible="not id">
                    <field name="rd_count" widget="statinfo" string="Rewards &amp; Discipline"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_view_form_inherit_rd" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.rd</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- Smart buttons: separate counts for reward and discipline -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_reward_records"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-star"
                        groups="hr.group_hr_user"
                        invisible="not id">
                    <field name="reward_count" widget="statinfo" string="Khen thưởng"/>
                </button>
                <button name="action_open_discipline_records"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-gavel"
                        groups="hr.group_hr_user"
                        invisible="not id">
                    <field name="discipline_count" widget="statinfo" string="Kỷ luật"/>
                </button>
            </xpath>
            <!-- History tab inside employee form -->
            <xpath expr="//notebook" position="inside">
                <page string="Khen thưởng &amp; Kỷ luật" name="rd_history" groups="hr.group_hr_user" invisible="not id">
                    <field name="rd_ids" readonly="1">
                        <list decoration-success="state == 'confirmed'" decoration-muted="state == 'cancelled'"
                              string="Lịch sử khen thưởng / kỷ luật">
                            <field name="name"/>
                            <field name="rd_type_id" string="Loại"/>
                            <field name="category" widget="badge"
                                   decoration-success="category == 'reward'"
                                   decoration-danger="category == 'discipline'"/>
                            <field name="date" string="Ngày"/>
                            <field name="decision_number" string="Số QĐ"/>
                            <field name="amount" string="Giá trị"/>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'confirmed'"
                                   decoration-muted="state == 'cancelled'"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

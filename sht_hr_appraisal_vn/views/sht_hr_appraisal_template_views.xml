<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_appraisal_template_view_form" model="ir.ui.view">
        <field name="name">sht.hr.appraisal.template.form</field>
        <field name="model">sht.hr.appraisal.template</field>
        <field name="arch" type="xml">
            <form string="Mẫu đánh giá">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Tên mẫu đánh giá..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="department_id"/>
                            <field name="job_id"/>
                        </group>
                        <group>
                            <field name="total_weight"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tiêu chí" name="criteria">
                            <field name="criteria_ids">
                                <list>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="category" widget="badge"/>
                                    <field name="weight"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghi chú" name="notes">
                            <field name="note" placeholder="Ghi chú..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sht_hr_appraisal_template_view_list" model="ir.ui.view">
        <field name="name">sht.hr.appraisal.template.list</field>
        <field name="model">sht.hr.appraisal.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="total_weight"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_appraisal_template_action" model="ir.actions.act_window">
        <field name="name">Mẫu đánh giá</field>
        <field name="res_model">sht.hr.appraisal.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_appraisal_cycle_view_form" model="ir.ui.view">
        <field name="name">sht.hr.appraisal.cycle.form</field>
        <field name="model">sht.hr.appraisal.cycle</field>
        <field name="arch" type="xml">
            <form string="Kỳ đánh giá">
                <header>
                    <button name="action_start" string="Bắt đầu" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_generate_appraisals" string="Tạo phiếu đánh giá"
                            type="object" class="btn-primary"
                            invisible="state != 'in_progress'"/>
                    <button name="action_complete" string="Hoàn thành" type="object"
                            class="btn-success" invisible="state != 'in_progress'"
                            confirm="Hoàn thành kỳ đánh giá này?"/>
                    <button name="action_draft" string="Về nháp" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-clipboard"
                                type="object" name="action_view_appraisals"
                                invisible="total_count == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="completed_count"/>/<field name="total_count"/>
                                </span>
                                <span class="o_stat_text">Phiếu ĐG</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="period_type"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group>
                            <field name="template_id"/>
                            <field name="department_ids" widget="many2many_tags"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Phiếu đánh giá" name="appraisals">
                            <field name="appraisal_ids">
                                <list>
                                    <field name="employee_id"/>
                                    <field name="department_id"/>
                                    <field name="date_close"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghi chú" name="notes">
                            <field name="note" placeholder="Ghi chú..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="sht_hr_appraisal_cycle_view_list" model="ir.ui.view">
        <field name="name">sht.hr.appraisal.cycle.list</field>
        <field name="model">sht.hr.appraisal.cycle</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'"
                  decoration-success="state == 'in_progress'"
                  decoration-muted="state == 'completed'">
                <field name="name"/>
                <field name="period_type"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="total_count"/>
                <field name="completed_count"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'in_progress'"
                       decoration-warning="state == 'completed'"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_appraisal_cycle_action" model="ir.actions.act_window">
        <field name="name">Kỳ đánh giá</field>
        <field name="res_model">sht.hr.appraisal.cycle</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo kỳ đánh giá đầu tiên
            </p>
        </field>
    </record>
</odoo>

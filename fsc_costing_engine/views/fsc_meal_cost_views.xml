<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fsc_meal_cost_view_list" model="ir.ui.view">
        <field name="name">fsc.meal.cost.list</field>
        <field name="model">fsc.meal.cost</field>
        <field name="arch" type="xml">
            <list string="Meal Cost"
                  decoration-warning="variance_pct&gt;5"
                  decoration-danger="variance_pct&gt;15">
                <field name="create_date"/>
                <field name="production_id"/>
                <field name="meal_product_id"/>
                <field name="meal_qty"/>
                <field name="cost_per_meal_planned"/>
                <field name="cost_per_meal_actual"/>
                <field name="variance"/>
                <field name="variance_pct"/>
                <field name="currency_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="fsc_meal_cost_view_form" model="ir.ui.view">
        <field name="name">fsc.meal.cost.form</field>
        <field name="model">fsc.meal.cost</field>
        <field name="arch" type="xml">
            <form string="Meal Cost">
                <sheet>
                    <group>
                        <group>
                            <field name="production_id"/>
                            <field name="meal_product_id"/>
                            <field name="meal_qty"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="planned_cost_total"/>
                            <field name="actual_cost_total"/>
                            <field name="cost_per_meal_planned"/>
                            <field name="cost_per_meal_actual"/>
                            <field name="variance"/>
                            <field name="variance_pct"/>
                        </group>
                    </group>
                    <group string="Cost Breakdown">
                        <group>
                            <field name="raw_cost"/>
                            <field name="labor_cost"/>
                            <field name="overhead_cost"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="fsc_meal_cost_action" model="ir.actions.act_window">
        <field name="name">Meal Cost</field>
        <field name="res_model">fsc.meal.cost</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

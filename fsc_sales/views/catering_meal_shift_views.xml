<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="catering_meal_shift_view_list" model="ir.ui.view">
        <field name="name">catering.meal.shift.list</field>
        <field name="model">catering.meal.shift</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
                <field name="cutoff_offset_hours"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="catering_meal_shift_action" model="ir.actions.act_window">
        <field name="name">Meal Shifts</field>
        <field name="res_model">catering.meal.shift</field>
        <field name="view_mode">list</field>
    </record>

</odoo>

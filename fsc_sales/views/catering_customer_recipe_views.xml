<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="catering_customer_recipe_view_list" model="ir.ui.view">
        <field name="name">catering.customer.recipe.list</field>
        <field name="model">catering.customer.recipe</field>
        <field name="arch" type="xml">
            <list decoration-success="state=='active'" decoration-muted="state=='archived'">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="site_id" optional="show"/>
                <field name="meal_product_id"/>
                <field name="effective_from"/>
                <field name="effective_to" optional="show"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="catering_customer_recipe_view_form" model="ir.ui.view">
        <field name="name">catering.customer.recipe.form</field>
        <field name="model">catering.customer.recipe</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" type="object" string="Activate"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_archive_recipe" type="object" string="Archive"
                            invisible="state != 'active'"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="customer_id"/>
                            <field name="site_id"/>
                            <field name="meal_product_id"/>
                        </group>
                        <group>
                            <field name="base_bom_id"/>
                            <field name="effective_from"/>
                            <field name="effective_to"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ingredients">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="ingredient_id"/>
                                    <field name="qty_per_serving"/>
                                    <field name="uom_id"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="catering_customer_recipe_view_search" model="ir.ui.view">
        <field name="name">catering.customer.recipe.search</field>
        <field name="model">catering.customer.recipe</field>
        <field name="arch" type="xml">
            <search>
                <field name="customer_id"/>
                <field name="meal_product_id"/>
                <filter name="active" string="Active" domain="[('state','=','active')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_customer" string="Customer" context="{'group_by':'customer_id'}"/>
                    <filter name="group_meal" string="Meal" context="{'group_by':'meal_product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="catering_customer_recipe_action" model="ir.actions.act_window">
        <field name="name">Customer Recipes</field>
        <field name="res_model">catering.customer.recipe</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="catering_menu_plan_view_list" model="ir.ui.view">
        <field name="name">catering.menu.plan.list</field>
        <field name="model">catering.menu.plan</field>
        <field name="arch" type="xml">
            <list decoration-success="state in ('approved','locked')"
                  decoration-muted="state in ('cancelled',)"
                  decoration-warning="state=='changed'">
                <field name="name"/>
                <field name="week_start_date"/>
                <field name="week_end_date"/>
                <field name="customer_id"/>
                <field name="site_id"/>
                <field name="line_count"/>
                <field name="sale_order_count"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="catering_menu_plan_view_form" model="ir.ui.view">
        <field name="name">catering.menu.plan.form</field>
        <field name="model">catering.menu.plan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="btn-primary" invisible="state != 'submitted'"
                            groups="fsc_sales.group_planning_manager"/>
                    <button name="action_lock" type="object" string="Lock"
                            invisible="state != 'approved'"/>
                    <button name="action_generate_sales_orders" type="object"
                            string="Generate Sales Orders" class="btn-primary"
                            invisible="state not in ('approved','locked')"/>
                    <button name="action_request_change" type="object" string="Request Change"
                            invisible="state not in ('approved','locked')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('cancelled','draft')"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                            invisible="state in ('draft',)"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,locked"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sales_orders" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="sale_order_count == 0">
                            <field name="sale_order_count" widget="statinfo"
                                   string="Sales Orders"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="customer_id"/>
                            <field name="site_id"/>
                        </group>
                        <group>
                            <field name="week_start_date"/>
                            <field name="week_end_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Menu Lines">
                            <field name="line_ids" context="{'default_plan_id': id}">
                                <list editable="bottom">
                                    <field name="meal_date"/>
                                    <field name="weekday"/>
                                    <field name="shift_id"/>
                                    <field name="meal_product_id"/>
                                    <field name="planned_qty"/>
                                    <field name="actual_qty"/>
                                    <field name="variance_qty"/>
                                    <field name="variance_pct"/>
                                    <field name="customer_recipe_id" optional="show"/>
                                    <field name="sale_order_line_id" optional="show"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="catering_menu_plan_view_search" model="ir.ui.view">
        <field name="name">catering.menu.plan.search</field>
        <field name="model">catering.menu.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="site_id"/>
                <field name="week_start_date"/>
                <filter name="active" string="Active"
                        domain="[('state','in',['draft','submitted','approved','locked'])]"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="approved" string="Approved" domain="[('state','=','approved')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_customer" string="Customer" context="{'group_by':'customer_id'}"/>
                    <filter name="group_site" string="Site" context="{'group_by':'site_id'}"/>
                    <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="catering_menu_plan_action" model="ir.actions.act_window">
        <field name="name">Weekly Menu Plans</field>
        <field name="res_model">catering.menu.plan</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>

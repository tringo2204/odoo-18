<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_onboarding_sht_hr_checklist_view_list" model="ir.ui.view">
        <field name="name">sht.hr.checklist.list</field>
        <field name="model">sht.hr.checklist</field>
        <field name="arch" type="xml">
            <list string="Checklists">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="checklist_type"/>
                <field name="progress" widget="progressbar"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'done'"
                    decoration-muted="state == 'cancelled'"
                    decoration-info="state == 'in_progress'"/>
                <field name="date_start" optional="show"/>
                <field name="date_completed" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_onboarding_sht_hr_checklist_view_form" model="ir.ui.view">
        <field name="name">sht.hr.checklist.form</field>
        <field name="model">sht.hr.checklist</field>
        <field name="arch" type="xml">
            <form string="Checklist">
                <header>
                    <button name="action_generate_lines" type="object" string="Generate Lines"
                        class="btn-primary" invisible="state != 'in_progress'"
                        groups="hr.group_hr_manager"/>
                    <button name="action_mark_done" type="object" string="Mark Done"
                        invisible="state != 'in_progress'"
                        groups="hr.group_hr_manager"/>
                    <button name="action_cancel" type="object" string="Cancel"
                        invisible="state != 'in_progress'"
                        groups="hr.group_hr_manager"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="in_progress,done,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="template_id" domain="[('is_active', '=', True)]"/>
                            <field name="checklist_type"/>
                            <field name="date_start"/>
                            <field name="date_completed" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="progress" widget="progressbar"/>
                    </group>
                    <notebook>
                        <page string="Tasks" name="lines">
                            <field name="line_ids" nolabel="1" context="{'default_checklist_id': id}">
                                <list editable="bottom" create="1" delete="1">
                                    <field name="sequence" widget="handle"/>
                                    <field name="is_done" widget="boolean_toggle"/>
                                    <field name="name"/>
                                    <field name="responsible_role"/>
                                    <field name="done_by" optional="show"/>
                                    <field name="done_date" optional="show"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sht_hr_onboarding_sht_hr_checklist_view_search" model="ir.ui.view">
        <field name="name">sht.hr.checklist.search</field>
        <field name="model">sht.hr.checklist</field>
        <field name="arch" type="xml">
            <search string="Checklists">
                <field name="name"/>
                <field name="employee_id"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Onboarding" name="onboarding" domain="[('checklist_type', '=', 'onboarding')]"/>
                <filter string="Offboarding" name="offboarding" domain="[('checklist_type', '=', 'offboarding')]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'checklist_type'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="sht_hr_onboarding_sht_hr_checklist_action" model="ir.actions.act_window">
        <field name="name">Checklists</field>
        <field name="res_model">sht.hr.checklist</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sht_hr_onboarding_sht_hr_checklist_view_search"/>
    </record>
</odoo>

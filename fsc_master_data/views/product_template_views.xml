<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_view_form_fsc" model="ir.ui.view">
        <field name="name">product.template.form.fsc</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="FSC" name="fsc_master">
                    <group>
                        <group string="Classification">
                            <field name="fsc_product_type"/>
                            <field name="fsc_processing_type"/>
                            <field name="fsc_is_internal_supplier"/>
                        </group>
                        <group string="Yield &amp; Loss">
                            <field name="fsc_yield_expected"/>
                            <field name="fsc_loss_threshold"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>

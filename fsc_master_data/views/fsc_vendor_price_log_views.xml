<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fsc_vendor_price_log_view_list" model="ir.ui.view">
        <field name="name">fsc.vendor.price.log.list</field>
        <field name="model">fsc.vendor.price.log</field>
        <field name="arch" type="xml">
            <list string="Vendor Price Log">
                <field name="log_date"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="price_unit"/>
                <field name="currency_id" optional="hide"/>
                <field name="uom_id"/>
                <field name="source"/>
                <field name="source_ref" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="fsc_vendor_price_log_view_form" model="ir.ui.view">
        <field name="name">fsc.vendor.price.log.form</field>
        <field name="model">fsc.vendor.price.log</field>
        <field name="arch" type="xml">
            <form string="Vendor Price Log">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="product_id"/>
                            <field name="uom_id"/>
                        </group>
                        <group>
                            <field name="log_date"/>
                            <field name="price_unit"/>
                            <field name="currency_id"/>
                            <field name="source"/>
                            <field name="source_ref"/>
                        </group>
                    </group>
                    <group string="Note">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="fsc_vendor_price_log_view_search" model="ir.ui.view">
        <field name="name">fsc.vendor.price.log.search</field>
        <field name="model">fsc.vendor.price.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="source"/>
                <group expand="0" string="Group By">
                    <filter name="group_vendor" string="Vendor" context="{'group_by':'partner_id'}"/>
                    <filter name="group_product" string="Product" context="{'group_by':'product_id'}"/>
                    <filter name="group_source" string="Source" context="{'group_by':'source'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="fsc_vendor_price_log_action" model="ir.actions.act_window">
        <field name="name">Vendor Price Log</field>
        <field name="res_model">fsc.vendor.price.log</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

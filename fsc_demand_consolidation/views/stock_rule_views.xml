<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_rule_form_fsc" model="ir.ui.view">
        <field name="name">stock.rule.form.fsc</field>
        <field name="model">stock.rule</field>
        <field name="inherit_id" ref="stock.view_stock_rule_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='action']" position="after">
                <field name="fsc_consolidate"
                       invisible="action != 'buy'"
                       help="When set, demand routed through this buy rule goes into the FSC consolidation engine instead of generating an RFQ directly."/>
            </xpath>
        </field>
    </record>

</odoo>

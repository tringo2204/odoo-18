<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="cron_fsc_consolidate_demand" model="ir.cron">
        <field name="name">FSC: Consolidate Demand (debounce window)</field>
        <field name="model_id" ref="model_fsc_consolidation_line"/>
        <field name="state">code</field>
        <field name="code">model._cron_consolidate_demand()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

    <record id="fsc_consolidation_debounce_minutes" model="ir.config_parameter">
        <field name="key">fsc.consolidation.debounce_minutes</field>
        <field name="value">15</field>
    </record>

</odoo>

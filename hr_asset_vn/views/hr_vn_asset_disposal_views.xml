<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_vn_asset_disposal_view_list" model="ir.ui.view">
        <field name="name">hr.vn.asset.disposal.list</field>
        <field name="model">hr.vn.asset.disposal</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'done'"
                  decoration-info="state == 'approved'"
                  decoration-warning="state == 'submitted'"
                  decoration-muted="state == 'rejected'">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="asset_category_id"/>
                <field name="date"/>
                <field name="disposal_reason"/>
                <field name="residual_value"/>
                <field name="proposed_value"/>
                <field name="proposed_by_id"/>
                <field name="approved_by_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'approved'"
                       decoration-warning="state == 'submitted'"
                       decoration-muted="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="hr_vn_asset_disposal_view_form" model="ir.ui.view">
        <field name="name">hr.vn.asset.disposal.form</field>
        <field name="model">hr.vn.asset.disposal</field>
        <field name="arch" type="xml">
            <form string="Biên bản đề xuất thanh lý tài sản">
                <header>
                    <button name="action_submit" string="Gửi duyệt" type="object"
                            class="btn-primary" invisible="state != 'draft'"
                            groups="hr.group_hr_user"/>
                    <button name="action_approve" string="Phê duyệt" type="object"
                            class="btn-primary" invisible="state != 'submitted'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_reject" string="Từ chối" type="object"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_confirm_disposal" string="Hoàn tất thanh lý" type="object"
                            class="btn-danger" invisible="state != 'approved'"
                            groups="hr.group_hr_manager"
                            confirm="Xác nhận hoàn tất thanh lý? Tài sản sẽ được đánh dấu 'Đã thanh lý'."/>
                    <button name="action_reset_draft" string="Về nháp" type="object"
                            invisible="state not in ('rejected',)"
                            groups="hr.group_hr_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Số biên bản"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Tài sản">
                            <field name="asset_id" readonly="state != 'draft'"/>
                            <field name="asset_category_id" readonly="1"/>
                            <field name="asset_state" readonly="1"/>
                            <field name="current_employee_id" readonly="1"/>
                            <field name="residual_value" readonly="1"/>
                        </group>
                        <group string="Đề xuất">
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="disposal_reason" readonly="state != 'draft'"/>
                            <field name="proposed_value" readonly="state != 'draft'"/>
                            <field name="proposed_by_id" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="disposal_reason_note" string="Mô tả chi tiết"
                               colspan="2" readonly="state != 'draft'"
                               placeholder="Mô tả tình trạng tài sản, lý do cụ thể..."/>
                    </group>
                    <group string="Phê duyệt" invisible="state not in ('approved', 'done', 'rejected')">
                        <group>
                            <field name="approved_by_id" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="rejection_reason" invisible="state != 'rejected'"
                                   readonly="state != 'submitted'"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hr_vn_asset_disposal_view_search" model="ir.ui.view">
        <field name="name">hr.vn.asset.disposal.search</field>
        <field name="model">hr.vn.asset.disposal</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="asset_id" string="Tài sản"/>
                <separator/>
                <filter string="Chờ duyệt" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Đã duyệt" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Đã thanh lý" name="done" domain="[('state', '=', 'done')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Trạng thái" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Danh mục" name="group_cat" context="{'group_by': 'asset_category_id'}"/>
                    <filter string="Tháng" name="group_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_vn_asset_disposal" model="ir.actions.act_window">
        <field name="name">Biên bản thanh lý</field>
        <field name="res_model">hr.vn.asset.disposal</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_vn_asset_disposal_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Lập biên bản đề xuất thanh lý tài sản.</p>
        </field>
    </record>
</odoo>

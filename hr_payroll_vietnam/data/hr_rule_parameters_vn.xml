    <!-- ============================================================ -->
    <!-- Biểu thuế TNCN 7 bậc (list of tuples)                       -->
    <!-- ============================================================ -->
    <record id="vn_param_pit_brackets" model="hr.rule.parameter">
        <field name="name">VN: Biểu thuế TNCN lũy tiến (from, to, rate%)</field>
        <field name="code">vn_pit_brackets</field>
        <field name="country_id" ref="base.vn"/>
        <field name="description"><![CDATA[
            <p>Biểu thuế TNCN lũy tiến 7 bậc.</p>
            <p>Format: [(income_from, income_to, tax_rate_percent), ...]</p>
            <p>income_to = 0 nghĩa là không giới hạn (bậc cuối).</p>
        ]]></field>
    </record>
    <record id="vn_param_pit_brackets_2024" model="hr.rule.parameter.value">
        <field name="parameter_value">[(0, 5000000, 5), (5000000, 10000000, 10), (10000000, 18000000, 15), (18000000, 32000000, 20), (32000000, 52000000, 25), (52000000, 80000000, 30), (80000000, 0, 35)]</field>
        <field name="rule_parameter_id" ref="vn_param_pit_brackets"/>
        <field name="date_from" eval="datetime(2024, 1, 1).date()"/>
    </record>

    <!-- ============================================================ -->
    <!-- Lương vùng (dict)                                            -->
    <!-- ============================================================ -->
    <record id="vn_param_regional_wages" model="hr.rule.parameter">
        <field name="name">VN: Lương tối thiểu vùng</field>
        <field name="code">vn_regional_wages</field>
        <field name="country_id" ref="base.vn"/>
        <field name="description"><![CDATA[
            <p>Lương tối thiểu vùng I-IV. Dùng để tính trần BHTN.</p>
            <p>Format: {'1': amount, '2': amount, '3': amount, '4': amount}</p>
        ]]></field>
    </record>
    <record id="vn_param_regional_wages_2024" model="hr.rule.parameter.value">
        <field name="parameter_value">{'1': 4960000, '2': 4410000, '3': 3860000, '4': 3450000}</field>
        <field name="rule_parameter_id" ref="vn_param_regional_wages"/>
        <field name="date_from" eval="datetime(2024, 1, 1).date()"/>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_vn_dependent_view_list" model="ir.ui.view">
        <field name="name">hr.vn.dependent.list</field>
        <field name="model">hr.vn.dependent</field>
        <field name="arch" type="xml">
                <list>
                <field name="employee_id"/>
                <field name="name"/>
                <field name="relationship"/>
                <field name="id_number"/>
                <field name="tax_code"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="tax_office_confirmed"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="hr_vn_dependent_view_form" model="ir.ui.view">
        <field name="name">hr.vn.dependent.form</field>
        <field name="model">hr.vn.dependent</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Duyệt" type="object"
                            class="btn-primary" invisible="status != 'pending'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_expire" string="Hết hạn" type="object"
                            invisible="status != 'approved'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_reset_pending" string="Chờ duyệt lại" type="object"
                            invisible="status == 'pending'"
                            groups="hr.group_hr_manager"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,approved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="name"/>
                            <field name="id_number"/>
                            <field name="tax_code"/>
                            <field name="relationship"/>
                            <field name="date_of_birth"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="tax_office_confirmed"/>
                            <field name="status"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_vn_dependent_action" model="ir.actions.act_window">
        <field name="name">Người phụ thuộc</field>
        <field name="res_model">hr.vn.dependent</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

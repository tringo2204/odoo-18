<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- #173: Đổi tiêu đề form 'Payslips Batches' → 'Đợt trả lương' -->
    <record id="hr_payslip_run_view_form_title_vn" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.title.vn</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">
            <form position="attributes">
                <attribute name="string">Đợt trả lương</attribute>
            </form>
        </field>
    </record>

    <record id="hr_payslip_run_view_form_inherit_vn" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.inherit.vn</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_compute" string="Tính lương" type="object"
                        class="btn-primary" invisible="approval_state != 'draft'"/>
                <button name="action_approve" string="Phê duyệt" type="object"
                        class="btn-primary" invisible="approval_state != 'computed'"
                        groups="hr.group_hr_manager"/>
                <button name="action_mark_paid" string="Đã trả lương" type="object"
                        class="btn-success" invisible="approval_state != 'approved'"/>
                <button name="action_open_bank_export" string="Xuất file NH" type="object"
                        class="btn-secondary" invisible="approval_state not in ('approved', 'paid')"/>
                <button name="action_reset_draft" string="Về nháp" type="object"
                        invisible="approval_state in ('draft', 'paid')"/>
                <field name="approval_state" widget="statusbar"
                       statusbar_visible="draft,computed,approved,paid"/>
            </xpath>
            <xpath expr="//group" position="after">
                <group string="Tổng hợp lương">
                    <group>
                        <field name="employee_count"/>
                        <field name="total_gross"/>
                        <field name="total_net"/>
                    </group>
                    <group>
                        <field name="total_insurance"/>
                        <field name="total_pit"/>
                        <field name="approved_by"/>
                        <field name="approved_date"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
    <!-- #169: Dịch tab 'Other Info' → 'Thông tin khác' trong phiếu lương -->
    <!-- #172: Hiển thị khấu trừ hàng tháng trong tab Tính toán lương -->
    <record id="hr_payslip_view_form_tab_vn" model="ir.ui.view">
        <field name="name">hr.payslip.form.tab.vn</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <page name="account_info" position="attributes">
                <attribute name="string">Thông tin khác</attribute>
            </page>
            <page name="worked_days_input" position="attributes">
                <attribute name="string">Ngày công &amp; Đầu vào</attribute>
            </page>
            <page name="salary_computation" position="attributes">
                <attribute name="string">Tính toán lương</attribute>
            </page>
            <page name="salary_computation" position="inside">
                <group string="Khấu trừ lương hàng tháng"
                       invisible="not monthly_deduction">
                    <group>
                        <field name="monthly_deduction" readonly="1"/>
                        <field name="deduction_note" readonly="1"/>
                    </group>
                </group>
            </page>
        </field>
    </record>
</odoo>

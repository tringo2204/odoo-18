<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_sign_request_view_form" model="ir.ui.view">
        <field name="name">hr.sign.request.form</field>
        <field name="model">hr.sign.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send" string="Gửi ký" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Hủy" type="object" invisible="state in ('fully_signed', 'cancelled')"/>
                    <button name="action_draft" string="Về nháp" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,sent,partially_signed,fully_signed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="document_type"/><field name="employee_id"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="document_file" filename="document_filename"/>
                            <field name="document_filename" invisible="1"/>
                            <field name="signed_file" filename="signed_filename" invisible="not signed_file"/>
                            <field name="signed_filename" invisible="1"/>
                            <field name="date_sent"/><field name="date_completed"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Người ký" name="signers">
                            <field name="signer_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="signer_id"/><field name="role"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'pending'"
                                           decoration-success="state == 'signed'"
                                           decoration-danger="state == 'refused'"/>
                                    <field name="signed_date"/>
                                    <field name="signature_type"/>
                                    <field name="note"/>
                                    <button name="action_sign" string="Ký" type="object" icon="fa-pencil"
                                            invisible="state != 'pending'"/>
                                    <button name="action_refuse" string="Từ chối" type="object" icon="fa-times"
                                            invisible="state != 'pending'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghi chú"><field name="note"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="hr_sign_request_view_list" model="ir.ui.view">
        <field name="name">hr.sign.request.list</field>
        <field name="model">hr.sign.request</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'fully_signed'" decoration-muted="state == 'cancelled'">
                <field name="name"/><field name="document_type"/><field name="employee_id"/>
                <field name="date_sent"/><field name="date_completed"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="hr_sign_request_action" model="ir.actions.act_window">
        <field name="name">Yêu cầu ký số</field>
        <field name="res_model">hr.sign.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_sign_template_view_form" model="ir.ui.view">
        <field name="name">hr.sign.template.form</field>
        <field name="model">hr.sign.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/><field name="job_id"/><field name="user_id"/>
                        </group>
                        <group>
                            <field name="is_initial"/><field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="signature_image" widget="image"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="hr_sign_template_view_list" model="ir.ui.view">
        <field name="name">hr.sign.template.list</field>
        <field name="model">hr.sign.template</field>
        <field name="arch" type="xml">
            <list><field name="name"/><field name="job_id"/><field name="user_id"/><field name="is_initial"/></list>
        </field>
    </record>
    <record id="hr_sign_template_action" model="ir.actions.act_window">
        <field name="name">Mẫu chữ ký</field>
        <field name="res_model">hr.sign.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

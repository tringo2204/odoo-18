<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="hr_request_comp_rule" model="ir.rule">
        <field name="name">Đơn từ: Multi-company</field>
        <field name="model_id" ref="model_hr_request"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="hr_request_type_comp_rule" model="ir.rule">
        <field name="name">Loại đơn: Multi-company</field>
        <field name="model_id" ref="model_hr_request_type"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <!-- Portal users can only see their own requests -->
    <record id="hr_request_portal_rule" model="ir.rule">
        <field name="name">Đơn từ: Portal — own requests only</field>
        <field name="model_id" ref="model_hr_request"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
    </record>

    <!-- Regular employees can only see their own requests -->
    <record id="hr_request_employee_rule" model="ir.rule">
        <field name="name">Đơn từ: Nhân viên — chỉ thấy đơn của mình</field>
        <field name="model_id" ref="model_hr_request"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[
            '|',
            ('employee_id.user_id', '=', user.id),
            ('created_by_id', '=', user.id)
        ]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- HR Officers (group_hr_user) see own + direct reports + department -->
    <record id="hr_request_manager_rule" model="ir.rule">
        <field name="name">Đơn từ: Quản lý — thấy đơn cấp dưới và phòng ban</field>
        <field name="model_id" ref="model_hr_request"/>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="domain_force">['|', '|', '|',
            ('employee_id.user_id', '=', user.id),
            ('created_by_id', '=', user.id),
            ('employee_id.parent_id.user_id', '=', user.id),
            ('employee_id.department_id.manager_id.user_id', '=', user.id)
        ]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- HR Managers (group_hr_manager) see all requests -->
    <record id="hr_request_hr_manager_rule" model="ir.rule">
        <field name="name">Đơn từ: HR Manager — thấy tất cả</field>
        <field name="model_id" ref="model_hr_request"/>
        <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>

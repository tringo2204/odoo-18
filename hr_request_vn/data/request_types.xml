<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="request_type_leave" model="hr.request.type">
        <field name="name">Đơn xin nghỉ</field>
        <field name="code">LEAVE</field>
        <field name="sequence">1</field>
    </record>
    <record id="request_type_absence" model="hr.request.type">
        <field name="name">Đơn vắng mặt</field>
        <field name="code">ABSENCE</field>
        <field name="sequence">2</field>
    </record>
    <record id="request_type_ot" model="hr.request.type">
        <field name="name">Đơn làm thêm giờ</field>
        <field name="code">OT</field>
        <field name="sequence">3</field>
    </record>
    <record id="request_type_checkin" model="hr.request.type">
        <field name="name">Đơn bổ sung chấm công</field>
        <field name="code">CHECKIN</field>
        <field name="sequence">4</field>
    </record>
    <record id="request_type_shift_swap" model="hr.request.type">
        <field name="name">Đơn đổi ca</field>
        <field name="code">SHIFT_SWAP</field>
        <field name="sequence">5</field>
    </record>
    <record id="request_type_extra_shift" model="hr.request.type">
        <field name="name">Đơn tăng ca</field>
        <field name="code">EXTRA_SHIFT</field>
        <field name="sequence">6</field>
    </record>
    <record id="request_type_shift_reg" model="hr.request.type">
        <field name="name">Đơn đăng ký ca</field>
        <field name="code">SHIFT_REG</field>
        <field name="sequence">7</field>
    </record>
    <record id="request_type_business_trip" model="hr.request.type">
        <field name="name">Đơn công tác</field>
        <field name="code">BUSINESS_TRIP</field>
        <field name="sequence">8</field>
    </record>
    <record id="request_type_special" model="hr.request.type">
        <field name="name">Đơn làm theo chế độ</field>
        <field name="code">SPECIAL_SCHEDULE</field>
        <field name="sequence">9</field>
    </record>
    <record id="request_type_resignation" model="hr.request.type">
        <field name="name">Đơn thôi việc</field>
        <field name="code">RESIGNATION</field>
        <field name="sequence">10</field>
    </record>

    <!-- Default approval rules: direct manager -->
    <record id="rule_leave_manager" model="hr.request.approval.rule">
        <field name="request_type_id" ref="request_type_leave"/>
        <field name="approver_type">direct_manager</field>
        <field name="sequence">10</field>
    </record>
    <record id="rule_ot_manager" model="hr.request.approval.rule">
        <field name="request_type_id" ref="request_type_ot"/>
        <field name="approver_type">direct_manager</field>
        <field name="sequence">10</field>
    </record>
    <record id="rule_checkin_manager" model="hr.request.approval.rule">
        <field name="request_type_id" ref="request_type_checkin"/>
        <field name="approver_type">direct_manager</field>
        <field name="sequence">10</field>
    </record>
    <record id="rule_resignation_manager" model="hr.request.approval.rule">
        <field name="request_type_id" ref="request_type_resignation"/>
        <field name="approver_type">direct_manager</field>
        <field name="sequence">10</field>
    </record>
    <record id="rule_resignation_hr" model="hr.request.approval.rule">
        <field name="request_type_id" ref="request_type_resignation"/>
        <field name="approver_type">hr</field>
        <field name="sequence">20</field>
    </record>
</odoo>

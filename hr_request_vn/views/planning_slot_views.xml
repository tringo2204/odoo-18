<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- #Fix Row 6: Bổ sung filter/group_by phân ca theo nhóm nhân viên + vị trí làm việc.
         Planning Enterprise đã có department_id, job_title, manager_id sẵn.
         Bổ sung: category_ids (Nhóm NV), work_location_id (Vị trí làm việc). -->
    <record id="planning_view_search_vn" model="ir.ui.view">
        <field name="name">planning.slot.search.vn</field>
        <field name="model">planning.slot</field>
        <field name="inherit_id" ref="planning.planning_view_search_base"/>
        <field name="arch" type="xml">
            <field name="department_id" position="after">
                <field name="work_location_id" string="Vị trí làm việc"
                       groups="planning.group_planning_user"/>
            </field>
            <filter name="group_by_department" position="after">
                <filter name="group_by_work_location" string="Vị trí làm việc"
                        context="{'group_by': 'work_location_id'}"
                        groups="planning.group_planning_user"/>
                <filter name="group_by_job_title" string="Chức danh"
                        context="{'group_by': 'job_title'}"
                        groups="planning.group_planning_user"/>
            </filter>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_request_type_view_list" model="ir.ui.view">
        <field name="name">hr.request.type.list</field>
        <field name="model">hr.request.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="allow_proxy_create"/>
                <field name="frequency_limit"/>
            </list>
        </field>
    </record>

    <record id="hr_request_type_view_form" model="ir.ui.view">
        <field name="name">hr.request.type.form</field>
        <field name="model">hr.request.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="allow_proxy_create"/>
                            <field name="create_deadline_days"/>
                            <field name="frequency_limit"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lý do">
                            <field name="reason_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Quy tắc phê duyệt">
                            <field name="approval_rule_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="approver_type"/>
                                    <field name="approver_user_id"
                                           invisible="approver_type != 'specific_user'"/>
                                    <field name="required"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_request_type_action" model="ir.actions.act_window">
        <field name="name">Cài đặt loại đơn</field>
        <field name="res_model">hr.request.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List -->
    <record id="hr_request_view_list" model="ir.ui.view">
        <field name="name">hr.request.list</field>
        <field name="model">hr.request</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-warning="state == 'submitted'"
                  decoration-success="state == 'approved'" decoration-danger="state == 'refused'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="request_type_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="duration_days" string="Ngày"
                       invisible="request_type_code == 'ABSENCE'"/>
                <field name="absence_duration_hours" string="Số giờ" optional="show"
                       invisible="request_type_code != 'ABSENCE'"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state in ('refused', 'cancelled')"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="hr_request_view_form" model="ir.ui.view">
        <field name="name">hr.request.form</field>
        <field name="model">hr.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Nộp đơn" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_open_approve_wizard" string="Phê duyệt" type="object"
                            class="btn-primary" invisible="state != 'submitted'"
                            groups="hr.group_hr_user"/>
                    <button name="action_open_refuse_wizard" string="Từ chối" type="object"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_user"/>
                    <button name="action_cancel" string="Hủy đơn" type="object"
                            invisible="state not in ('draft', 'submitted')"/>
                    <button name="action_draft" string="Đặt lại nháp" type="object"
                            invisible="state not in ('refused', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,refused,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="state != 'draft'"/></h1>
                    </div>
                    <!-- #99: explicit readonly on each field (group-level readonly not reliable in Odoo 18) -->
                    <group>
                        <group>
                            <field name="request_type_id" readonly="state != 'draft'"/>
                            <field name="request_type_code" invisible="1"/>
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="reason_id" readonly="state != 'draft'"/>
                            <field name="created_by_id" readonly="1"/>
                        </group>
                        <!-- #82: hide generic date group for SPECIAL_SCHEDULE too -->
                        <!-- #60: LEAVE uses date-only fields in its own section below -->
                        <!-- ABSENCE removed from group invisible so duration_hours is
                             effectively visible for ABSENCE (field-level invisible excludes ABSENCE).
                             Individual fields hide themselves for ABSENCE where not needed. -->
                        <!-- #68: CHECKIN / BUSINESS_TRIP added so type-specific sections
                             handle their own date fields without duplication -->
                        <group invisible="request_type_code in ('RESIGNATION', 'SHIFT_SWAP', 'SHIFT_REG', 'EXTRA_SHIFT', 'SPECIAL_SCHEDULE', 'LEAVE', 'CHECKIN', 'BUSINESS_TRIP')">
                            <field name="date_from"
                                   invisible="request_type_code == 'ABSENCE'"
                                   readonly="state != 'draft'"/>
                            <!-- #80: hide date_to for BUSINESS_TRIP and ABSENCE -->
                            <field name="date_to"
                                   invisible="request_type_code in ('BUSINESS_TRIP', 'ABSENCE')"
                                   readonly="state != 'draft'"/>
                            <!-- #77/#63: visible for OT; ABSENCE hidden here (shown in ABSENCE section) -->
                            <!-- Row 78: ABSENCE added to avoid duplicate hours in top group -->
                            <field name="duration_hours"
                                   invisible="request_type_code in ('LEAVE', 'SHIFT_SWAP', 'EXTRA_SHIFT', 'SHIFT_REG', 'BUSINESS_TRIP', 'RESIGNATION', 'SPECIAL_SCHEDULE', 'ABSENCE')"
                                   readonly="1"/>
                            <!-- #80: show calendar days for BUSINESS_TRIP -->
                            <field name="duration_calendar_days"
                                   invisible="request_type_code != 'BUSINESS_TRIP'"/>
                            <field name="duration_days"
                                   invisible="request_type_code in ('ABSENCE', 'OT', 'SHIFT_SWAP', 'EXTRA_SHIFT', 'SHIFT_REG', 'BUSINESS_TRIP', 'RESIGNATION')"
                                   readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company"
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <!-- LEAVE -->
                    <!-- #60: show date_from/to as date-only (widget=date hides time/hour component) -->
                    <group string="Thông tin nghỉ phép" invisible="request_type_code != 'LEAVE'"
                           readonly="state != 'draft'">
                        <group>
                            <field name="date_from" string="Từ ngày" widget="date"
                                   required="request_type_code == 'LEAVE'"/>
                            <field name="date_to" string="Đến ngày" widget="date"
                                   required="request_type_code == 'LEAVE'"/>
                            <field name="duration_days" string="Số ngày" readonly="1"/>
                        </group>
                        <group>
                            <!-- #85/#68: only show day-based leave types, exclude absence (hour) and business trip (other) -->
                            <field name="leave_type_id" required="request_type_code == 'LEAVE'"
                                   domain="[('requires_allocation', '=', 'no'), ('request_unit', '!=', 'hour'), ('time_type', '=', 'leave')]"/>
                        </group>
                    </group>

                    <!-- ABSENCE (hour-based) -->
                    <!-- #63: hide Số ngày, show Số giờ via absence_duration_hours in this section -->
                    <group string="Thông tin vắng mặt" invisible="request_type_code != 'ABSENCE'"
                           readonly="state != 'draft'">
                        <group>
                            <field name="absence_date" required="request_type_code == 'ABSENCE'"/>
                            <field name="request_hour_from" widget="float_time"
                                   required="request_type_code == 'ABSENCE'"/>
                            <field name="request_hour_to" widget="float_time"
                                   required="request_type_code == 'ABSENCE'"/>
                            <field name="absence_duration_hours" string="Số giờ" readonly="1"/>
                        </group>
                    </group>

                    <!-- CHECKIN: #68 use date range (check_in + check_out) instead of
                         type+single-time; user enters start and end of the missed period -->
                    <group string="Bổ sung chấm công" invisible="request_type_code != 'CHECKIN'"
                           readonly="state != 'draft'">
                        <group>
                            <field name="date_from" string="Giờ check-in"
                                   required="request_type_code == 'CHECKIN'"/>
                            <field name="date_to" string="Giờ check-out"
                                   required="request_type_code == 'CHECKIN'"/>
                            <field name="duration_hours" string="Số giờ" readonly="1"/>
                        </group>
                    </group>

                    <!-- SHIFT_SWAP -->
                    <group string="Đổi ca" invisible="request_type_code != 'SHIFT_SWAP'"
                           readonly="state != 'draft'">
                        <group>
                            <field name="shift_from_id" domain="[('resource_id.employee_id', '=', employee_id)]"/>
                            <field name="shift_from_start" readonly="1" invisible="not shift_from_id"/>
                            <field name="shift_from_end" readonly="1" invisible="not shift_from_id"/>
                            <field name="swap_employee_id"/>
                        </group>
                        <group>
                            <!-- #72: show all slots when no partner selected; filter by partner when set -->
                            <!-- Row 83: required so user cannot save/submit without picking a target shift -->
                            <field name="shift_to_id"
                                   required="request_type_code == 'SHIFT_SWAP'"
                                   domain="[('resource_id.employee_id', '=', swap_employee_id)] if swap_employee_id else [('resource_id', '!=', False)]"/>
                            <field name="shift_to_start" readonly="1" invisible="not shift_to_id"/>
                            <field name="shift_to_end" readonly="1" invisible="not shift_to_id"/>
                        </group>
                    </group>

                    <!-- EXTRA_SHIFT -->
                    <group string="Tăng ca" invisible="request_type_code != 'EXTRA_SHIFT'"
                           readonly="state != 'draft'">
                        <group>
                            <field name="extra_shift_date"/>
                            <field name="extra_shift_start" widget="float_time"/>
                            <field name="extra_shift_end" widget="float_time"/>
                            <!-- Row 95: show computed hours -->
                            <field name="extra_shift_hours" string="Số giờ tăng ca" readonly="1"/>
                        </group>
                    </group>

                    <!-- SHIFT_REG -->
                    <group string="Đăng ký ca" invisible="request_type_code != 'SHIFT_REG'"
                           readonly="state != 'draft'">
                        <group>
                            <field name="shift_reg_date"/>
                            <field name="shift_reg_start" widget="float_time"/>
                            <field name="shift_reg_end" widget="float_time"/>
                            <!-- Row 98: show computed hours -->
                            <field name="shift_reg_hours" string="Số giờ" readonly="1"/>
                        </group>
                    </group>

                    <!-- BUSINESS_TRIP (#80: show date range + calendar days) -->
                    <group string="Công tác" invisible="request_type_code != 'BUSINESS_TRIP'"
                           readonly="state != 'draft'">
                        <group>
                            <field name="date_from" string="Từ ngày"/>
                            <field name="date_to" string="Đến ngày"/>
                            <field name="duration_calendar_days" string="Số ngày" readonly="1"/>
                            <field name="business_trip_location"/>
                        </group>
                    </group>

                    <!-- SPECIAL_SCHEDULE (#81/#82: date + deviation minutes) -->
                    <group string="Chế độ đặc biệt" invisible="request_type_code != 'SPECIAL_SCHEDULE'"
                           readonly="state != 'draft'">
                        <group>
                            <field name="special_schedule_type"/>
                            <field name="date_from" string="Ngày áp dụng"/>
                        </group>
                        <group>
                            <field name="late_minutes"
                                   invisible="special_schedule_type != 'late_arrival'"
                                   string="Số phút đi muộn"/>
                            <field name="early_minutes"
                                   invisible="special_schedule_type != 'early_departure'"
                                   string="Số phút về sớm"/>
                        </group>
                    </group>

                    <!-- RESIGNATION -->
                    <group string="Thông tin thôi việc" invisible="request_type_code != 'RESIGNATION'"
                           readonly="state != 'draft'">
                        <group>
                            <field name="resignation_date"
                                   required="request_type_code == 'RESIGNATION'"/>
                            <field name="resignation_last_working_date"
                                   required="request_type_code == 'RESIGNATION'"/>
                            <field name="resignation_announcement_date"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Mô tả">
                            <field name="description" placeholder="Lý do chi tiết..."
                                   readonly="state != 'draft'"/>
                        </page>
                        <page string="Phê duyệt">
                            <!-- #88: show expected approvers from request type rules in draft -->
                            <group string="Luồng phê duyệt dự kiến"
                                   invisible="state != 'draft' or not request_type_id">
                                <field name="approval_rule_ids" readonly="1" nolabel="1">
                                    <list string="Quy tắc phê duyệt">
                                        <field name="sequence" string="Thứ tự"/>
                                        <field name="approver_type" string="Loại người duyệt"/>
                                        <field name="approver_user_id" string="Người cụ thể"/>
                                    </list>
                                </field>
                            </group>
                            <!-- Actual approval records after submission -->
                            <field name="approval_ids" readonly="1"
                                   invisible="state == 'draft'">
                                <list>
                                    <field name="sequence"/>
                                    <field name="approver_id"/>
                                    <field name="status" widget="badge"
                                           decoration-info="status == 'pending'"
                                           decoration-success="status == 'approved'"
                                           decoration-danger="status == 'refused'"/>
                                    <field name="approved_date"/>
                                    <field name="note" string="Nhận xét của người duyệt"/>
                                </list>
                            </field>
                        </page>
                        <!-- #76/#78: always show for EXTRA_SHIFT/SHIFT_REG/SHIFT_SWAP; also show when linked records exist -->
                        <page string="Liên kết" groups="hr.group_hr_user"
                              invisible="request_type_code not in ('EXTRA_SHIFT', 'SHIFT_REG', 'SHIFT_SWAP') and not leave_id and not attendance_id">
                            <group>
                                <field name="leave_id" readonly="1" invisible="not leave_id"/>
                                <field name="attendance_id" readonly="1" invisible="not attendance_id"/>
                                <field name="planning_slot_id" readonly="1"
                                       invisible="not planning_slot_id and request_type_code not in ('EXTRA_SHIFT', 'SHIFT_REG')"/>
                                <field name="shift_from_id" readonly="1"
                                       invisible="request_type_code != 'SHIFT_SWAP' or not shift_from_id"/>
                                <field name="shift_to_id" readonly="1"
                                       invisible="request_type_code != 'SHIFT_SWAP' or not shift_to_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search -->
    <record id="hr_request_view_search" model="ir.ui.view">
        <field name="name">hr.request.search</field>
        <field name="model">hr.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="request_type_id"/>
                <filter string="Đơn của tôi" name="my_requests"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <filter string="Chờ duyệt" name="to_approve"
                        domain="[('state', '=', 'submitted')]"/>
                <filter string="Đã duyệt" name="approved"
                        domain="[('state', '=', 'approved')]"/>
                <separator/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Loại đơn" name="group_type" context="{'group_by': 'request_type_id'}"/>
                    <filter string="Trạng thái" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Nhân viên" name="group_employee" context="{'group_by': 'employee_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="hr_request_action_my" model="ir.actions.act_window">
        <field name="name">Đơn từ của tôi</field>
        <field name="res_model">hr.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_requests': 1}</field>
    </record>

    <record id="hr_request_action_to_approve" model="ir.actions.act_window">
        <field name="name">Đơn cần duyệt</field>
        <field name="res_model">hr.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_to_approve': 1}</field>
    </record>

    <record id="hr_request_action_all" model="ir.actions.act_window">
        <field name="name">Tất cả đơn từ</field>
        <field name="res_model">hr.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

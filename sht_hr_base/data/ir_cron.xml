<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="cron_negative_leave_alert" model="ir.cron">
        <field name="name">Cảnh báo phép âm</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">model._cron_negative_leave_alert()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">weeks</field>
        <field name="active">True</field>
    </record>

    <record id="cron_attendance_anomaly_alert" model="ir.cron">
        <field name="name">Cảnh báo chấm công bất thường</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">model._cron_attendance_anomaly_alert()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>

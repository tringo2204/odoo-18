<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_base_view_sht_hr_employee_document_tree" model="ir.ui.view">
        <field name="name">sht.hr.employee.document.tree</field>
        <field name="model">sht.hr.employee.document</field>
        <field name="arch" type="xml">
            <list string="Employee Documents">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="document_type_id"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_base_view_sht_hr_employee_document_form" model="ir.ui.view">
        <field name="name">sht.hr.employee.document.form</field>
        <field name="model">sht.hr.employee.document</field>
        <field name="arch" type="xml">
            <form string="Employee Document">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="document_type_id"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                            <!-- #107: is_expired is auto-synced into state; show state only -->
                        </group>
                    </group>
                    <group>
                        <field name="attachment" filename="attachment_filename"/>
                        <field name="attachment_filename" invisible="1"/>
                    </group>
                    <group>
                        <field name="note" placeholder="Notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sht_hr_base_view_sht_hr_employee_document_search" model="ir.ui.view">
        <field name="name">sht.hr.employee.document.search</field>
        <field name="model">sht.hr.employee.document</field>
        <field name="arch" type="xml">
            <search string="Employee Documents">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="document_type_id"/>
                <separator/>
                <filter string="Còn hạn" name="state_valid" domain="[('state', '=', 'valid')]"/>
                <filter string="Hết hạn" name="state_expired" domain="[('state', '=', 'expired')]"/>
                <filter string="Thiếu" name="state_missing" domain="[('state', '=', 'missing')]"/>
                <group expand="0" string="Group By">
                    <filter string="Document Type" name="group_document_type" context="{'group_by': 'document_type_id'}"/>
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="sht_hr_base_action_sht_hr_employee_document" model="ir.actions.act_window">
        <field name="name">Employee Documents</field>
        <field name="res_model">sht.hr.employee.document</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sht_hr_base_view_sht_hr_employee_document_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Upload and track employee documents.</p>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_base_view_sht_hr_document_type_tree" model="ir.ui.view">
        <field name="name">sht.hr.document.type.tree</field>
        <field name="model">sht.hr.document.type</field>
        <field name="arch" type="xml">
            <list string="Loại tài liệu">
                <field name="name"/>
                <field name="code"/>
                <field name="is_required"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_base_view_sht_hr_document_type_form" model="ir.ui.view">
        <field name="name">sht.hr.document.type.form</field>
        <field name="model">sht.hr.document.type</field>
        <field name="arch" type="xml">
            <form string="Loại tài liệu">
                <sheet>
                    <group>
                        <field name="name" string="Tên loại tài liệu"/>
                        <field name="code" string="Mã"/>
                        <field name="is_required" string="Bắt buộc khi nhận việc"/>
                    </group>
                    <group>
                        <field name="description" string="Mô tả" placeholder="Mô tả..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sht_hr_base_view_sht_hr_document_type_search" model="ir.ui.view">
        <field name="name">sht.hr.document.type.search</field>
        <field name="model">sht.hr.document.type</field>
        <field name="arch" type="xml">
            <search string="Loại tài liệu">
                <field name="name" string="Tên loại tài liệu"/>
                <field name="code" string="Mã"/>
                <filter string="Bắt buộc khi nhận việc" name="filter_required_onboarding" domain="[('is_required', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="sht_hr_base_action_sht_hr_document_type" model="ir.actions.act_window">
        <field name="name">Loại tài liệu</field>
        <field name="res_model">sht.hr.document.type</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sht_hr_base_view_sht_hr_document_type_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo loại tài liệu cho hồ sơ nhân viên.</p>
        </field>
    </record>
</odoo>

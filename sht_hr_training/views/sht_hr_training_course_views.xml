<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_training_course_view_tree" model="ir.ui.view">
        <field name="name">sht.hr.training.course.list</field>
        <field name="model">sht.hr.training.course</field>
        <field name="arch" type="xml">
            <list string="Khóa học đào tạo">
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <field name="duration_hours"/>
                <field name="provider"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_training_course_view_form" model="ir.ui.view">
        <field name="name">sht.hr.training.course.form</field>
        <field name="model">sht.hr.training.course</field>
        <field name="arch" type="xml">
            <form string="Khóa học đào tạo">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="duration_hours"/>
                            <field name="provider"/>
                        </group>
                    </group>
                    <field name="description" widget="html"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sht_hr_training_course_view_search" model="ir.ui.view">
        <field name="name">sht.hr.training.course.search</field>
        <field name="model">sht.hr.training.course</field>
        <field name="arch" type="xml">
            <search string="Khóa học đào tạo">
                <field name="name"/>
                <field name="code" string="Mã"/>
                <field name="provider" string="Đơn vị đào tạo"/>
                <separator/>
                <filter name="sht_hr_training_course_filter_internal" string="Nội bộ" domain="[('category', '=', 'internal')]"/>
                <filter name="sht_hr_training_course_filter_external" string="Bên ngoài" domain="[('category', '=', 'external')]"/>
                <filter name="sht_hr_training_course_filter_online" string="Trực tuyến" domain="[('category', '=', 'online')]"/>
                <separator/>
                <filter name="sht_hr_training_course_filter_active" string="Đang hoạt động" domain="[('is_active', '=', True)]"/>
                <filter name="sht_hr_training_course_filter_inactive" string="Không hoạt động" domain="[('is_active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="sht_hr_training_course_action" model="ir.actions.act_window">
        <field name="name">Khóa học</field>
        <field name="res_model">sht.hr.training.course</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sht_hr_training_course_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo khóa học đào tạo cho catalog.</p>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sht_hr_training_plan_view_form" model="ir.ui.view">
        <field name="name">sht.hr.training.plan.form</field>
        <field name="model">sht.hr.training.plan</field>
        <field name="arch" type="xml">
            <form string="Kế hoạch đào tạo">
                <header>
                    <button name="action_approve" string="Duyệt" type="object"
                            class="btn-primary" invisible="state != 'draft'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_close" string="Đóng" type="object"
                            invisible="state != 'approved'"/>
                    <button name="action_draft" string="Về nháp" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,approved,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <!-- Row 149: widget="char" prevents locale thousands separator (2.025→2025) -->
                            <field name="year" widget="char"/>
                            <field name="department_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="budget"/>
                            <field name="spent"/>
                            <field name="remaining_budget"/>
                            <field name="training_count"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Khóa đào tạo" name="trainings">
                            <field name="training_ids">
                                <list>
                                    <field name="employee_id"/>
                                    <field name="course_id"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="cost"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghi chú" name="notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="sht_hr_training_plan_view_list" model="ir.ui.view">
        <field name="name">sht.hr.training.plan.list</field>
        <field name="model">sht.hr.training.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="year" widget="char"/>
                <field name="budget"/>
                <field name="spent"/>
                <field name="remaining_budget"/>
                <field name="training_count"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="sht_hr_training_plan_action" model="ir.actions.act_window">
        <field name="name">Kế hoạch đào tạo</field>
        <field name="res_model">sht.hr.training.plan</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

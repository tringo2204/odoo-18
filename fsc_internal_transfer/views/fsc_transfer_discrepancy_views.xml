<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fsc_transfer_discrepancy_view_list" model="ir.ui.view">
        <field name="name">fsc.transfer.discrepancy.list</field>
        <field name="model">fsc.transfer.discrepancy</field>
        <field name="arch" type="xml">
            <list string="Transfer Discrepancies"
                  decoration-danger="discrepancy_qty&lt;0"
                  decoration-muted="state=='resolved'">
                <field name="create_date"/>
                <field name="picking_id"/>
                <field name="product_id"/>
                <field name="warehouse_qty"/>
                <field name="kitchen_qty"/>
                <field name="discrepancy_qty"/>
                <field name="discrepancy_pct"/>
                <field name="resolution"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="fsc_transfer_discrepancy_view_form" model="ir.ui.view">
        <field name="name">fsc.transfer.discrepancy.form</field>
        <field name="model">fsc.transfer.discrepancy</field>
        <field name="arch" type="xml">
            <form string="Transfer Discrepancy">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="open,resolved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="picking_id"/>
                            <field name="product_id"/>
                            <field name="warehouse_confirmed_by"/>
                            <field name="kitchen_confirmed_by"/>
                        </group>
                        <group>
                            <field name="warehouse_qty"/>
                            <field name="kitchen_qty"/>
                            <field name="discrepancy_qty"/>
                            <field name="discrepancy_pct"/>
                            <field name="resolution"/>
                        </group>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="fsc_transfer_discrepancy_action" model="ir.actions.act_window">
        <field name="name">Transfer Discrepancies</field>
        <field name="res_model">fsc.transfer.discrepancy</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
